# .env.example
NODE_ENV=example
PORT=3000
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=secret
DB_NAME=clientes_puntos
KAYCLOAK_URL=keycloak_url.com
KEYCLOAK_REALM=FSA
KEYCLOAK_CLIENT_ID=puntos-fsa
KEYCLOAK_CLIENT_SECRET=xxxxx-xxxxxx-xxxxxx

# Metricas scheduler (solo se ejecuta en production y con flag habilitado)
METRICAS_CRON_ENABLED=false
METRICAS_CRON_EXPRESSION=*/10 * * * *

# WIBI sync temporal
WIBI_DUMP_DATABASE_URL=postgresql://postgres:WQqwYBgPkgYlVOnvKBRCrkSKDQVtwUzH@crossover.proxy.rlwy.net:19529/railway
WIBI_SYNC_BATCH_SIZE=1000
WIBI_SYNC_DRY_RUN_DEFAULT=true
WIBI_ORIGEN_TIPO=WIBI_SYNC_TEMP
WIBI_CLIENTES_TABLE=destino_clientes
WIBI_CLIENTES_ID_COLUMN=IdCliente
WIBI_CLIENTES_CARD_COLUMN=NroTarjeta
WIBI_CLIENTES_SALDO_COLUMN=SaldoPuntos
WIBI_MOVIMIENTOS_TABLE=destino_movimientos
WIBI_MOVIMIENTOS_ID_COLUMN=IdMovimiento
WIBI_MOVIMIENTOS_CLIENTE_ID_COLUMN=IdCliente
WIBI_MOVIMIENTOS_TS_COLUMN=FechaHora
WIBI_MOVIMIENTOS_PUNTOS_COLUMN=PuntosAcreditados
WIBI_MOVIMIENTOS_PUNTOS_DEBITO_COLUMN=
WIBI_MOVIMIENTOS_MONTO_COLUMN=Importe
WIBI_MOVIMIENTOS_TIPO_COLUMN=IdTipoMovimiento
WIBI_MOVIMIENTOS_DESCRIPCION_COLUMN=Motivo
